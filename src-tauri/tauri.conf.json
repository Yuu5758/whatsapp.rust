{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Whatsapp.rust",
  "version": "1.0.0",
  "identifier": "com.yuu5758.whatsapp.rust",
  "build": {
    "frontendDist": "../settings-ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "appimage", "app", "dmg", "nsis", "msi"],
    "macOS": {
      "minimumSystemVersion": "12.0"
    },
    "linux": {
      "deb": {
        "files": {
          "/usr/share/polkit-1/actions/com.yuu5758.whatsapp.rust.policy": "resources/com.yuu5758.whatsapp.rust.policy"
        }
      }
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
